<?xml version="1.0" encoding="UTF-8" ?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>Check_Issue_Type</name>
        <label>Check Issue Type</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>No_Results</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No Match</defaultConnectorLabel>
        <rules>
            <name>Is_Technical</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>issue_type</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>technical</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Mock_Results</targetReference>
            </connector>
            <label>Is Technical</label>
        </rules>
    </decisions>
    <assignments>
        <name>Mock_Results</name>
        <label>Mock Results</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>articles</assignToReference>
            <operator>Add</operator>
            <value>
                <stringValue>Article 1: How to Reset Password</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>top_article</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue
                >How to Reset Password: Go to Settings &gt; Security &gt; Reset Password. Click the reset link sent to your email.</stringValue>
            </value>
        </assignmentItems>
    </assignments>
    <assignments>
        <name>No_Results</name>
        <label>No Results</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>top_article</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue />
            </value>
        </assignmentItems>
    </assignments>
    <description
    >Stub flow for Search Knowledge Base — returns articles only for technical issues</description>
    <environments>Default</environments>
    <interviewLabel
    >SearchKnowledgeBase {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Search Knowledge Base</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Check_Issue_Type</targetReference>
        </connector>
    </start>
    <status>Active</status>
    <variables>
        <name>articles</name>
        <dataType>String</dataType>
        <isCollection>true</isCollection>
        <isInput>false</isInput>
        <isOutput>true</isOutput>
    </variables>
    <variables>
        <name>issue_type</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>keywords</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>top_article</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>true</isOutput>
    </variables>
</Flow>
